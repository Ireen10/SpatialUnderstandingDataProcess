# Environment configuration (copy to .env for local development)
PROJECT_NAME=SpatialUnderstandingDataProcess
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./spatial_data.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
DATA_STORAGE_PATH=./data
STORAGE_BACKEND=local

# S3 (optional)
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# Proxy (optional)
# HTTP_PROXY=
# HTTPS_PROXY=

# LLM (OpenRouter)
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Logging
LOG_LEVEL=INFO
