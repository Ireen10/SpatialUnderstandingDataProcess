# 生产环境配置示例
# 复制此文件为 .env 并修改配置

# 安全密钥（必须修改）
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters

# 数据库连接
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sudp
REDIS_URL=redis://redis:6379/0

# 数据存储路径
DATA_STORAGE_PATH=/data

# API 配置（可选）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80